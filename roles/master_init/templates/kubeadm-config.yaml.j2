apiVersion: kubeadm.k8s.io/v1beta4
kind: ClusterConfiguration
controlPlaneEndpoint: "{{ control_plane_endpoint }}:6443"
networking:
  podSubnet: "{{ pod_network_cidr }}"
---
apiVersion: kubeadm.k8s.io/v1beta4
kind: InitConfiguration
localAPIEndpoint:
  advertiseAddress: "{{ k8s_net_ip }}"
nodeRegistration:
  kubeletExtraArgs:
    - name: node-ip
      value: "{{ k8s_net_ip }}"
